{
  "formatting_checks": {
    "includes": [],
    "rules": [
      {
        "queries": ["varDecl(hasType(isConstQualified()), unless(matchesName(\"\\.*::[A-Z0-9_\\]+$\")), isExpansionInMainFile())"],
        "id": "FormattingConstant",
        "description": "Double check how you've formatted your constants."
      },
      {
        "queries": ["varDecl(unless(hasType(isConstQualified())), unless(matchesName(\".*::[a-z0-9_]+$\")), isExpansionInMainFile(), unless(parmVarDecl()))", "fieldDecl(unless(hasType(isConstQualified())), unless(matchesName(\".*::[a-z0-9_]+$\")), isExpansionInMainFile())"],
        "id": "FormattingVariable",
        "description": "Double check how you've formatted your variables."
      }
    ]
  },

  "always_checks": {
    "includes": [],
    "rules": [
      {
        "queries": ["varDecl(hasGlobalStorage(), isExpansionInMainFile(), unless(hasType(isConstQualified())))"],
        "id": "GlobalVariable",
        "description": "Make sure you aren't using any global variables."
      },
      {
        "queries": ["declRefExpr(to(functionDecl(hasName(\"printf\"))), isExpansionInMainFile())", "declRefExpr(to(functionDecl(hasName(\"scanf\"))), isExpansionInMainFile())"],
        "id": "Printf",
        "description": "Make sure to use the terminal read/write functions we're using."
      },
      {
        "queries": ["declRefExpr(to(varDecl(hasName(\"cin\"))), isExpansionInMainFile())", "declRefExpr(to(varDecl(hasName(\"cout\"))), isExpansionInMainFile())"],
        "id": "CppIO",
        "description": "Make sure to use the terminal read/write functions we're using."
      },
      {
        "queries": ["labelStmt(isExpansionInMainFile())", "gotoStmt(isExpansionInMainFile())"],
        "id": "Goto",
        "description": "Make sure to use structured control flow statements rather than jumping to labels."
      }
    ]
  },

  "base_checks": {
    "includes": ["formatting_checks", "always_checks"],
    "rules": []
  },

  "chapter_11_memory_deep_dive": {
    "includes": ["base_checks"],
    "rules": []
  },

  "chapter_10_pointers_and_lists": {
    "includes": ["chapter_11_memory_deep_dive"],
    "rules": [
      {
        "queries": ["declRefExpr(to(functionDecl(hasName(\"malloc\"))))", "declRefExpr(to(functionDecl(hasName(\"free\"))))"],
        "id": "Malloc",
        "description": "Try using C++ style memory allocation instead."
      },
      {
        "queries": ["cxxNewExpr(isExpansionInMainFile(), isArray())"],
        "id": "CppNewArray",
        "description": "Sorry, we'll cover dynamic arrays soon!"
      }
    ]
  },

  "chapter_09_generics_and_operators": {
    "includes": ["chapter_10_pointers_and_lists"],
    "rules": [
      {
        "queries": ["varDecl(hasType(qualType(hasUnqualifiedDesugaredType(pointerType(unless(pointee(hasDeclaration(isExpansionInFileMatching(\"splashkit/.*\")))))))), isExpansionInMainFile())"],
        "id": "Pointer",
        "description": "Still a bit early for pointers."
      },
      {
        "queries": ["cxxThisExpr(isExpansionInMainFile(), unless(anything()))"],
        "id": "This - NOTE: unless(isImplicit()) doesn't work on my machine, so for now this is nullified with anything()",
        "description": "No need to use `this` yet."
      },
      {
        "queries": ["cxxNewExpr(isExpansionInMainFile())"],
        "id": "CppNew",
        "description": "For now make sure to keep things on the stack."
      }
    ]
  },

  "chapter_08_member_functions": {
    "includes": ["chapter_09_generics_and_operators"],
    "rules": [
      {
        "queries": ["templateTypeParmDecl(isExpansionInMainFile())"],
        "id": "Template",
        "description": "For now just use concrete types - no need to generalize your code too much."
      },
      {
        "queries": ["functionDecl(matchesName(\"operator\"), isExpansionInMainFile())", "cxxMethodDecl(matchesName(\"operator\"), isExpansionInMainFile())"],
        "id": "OperatorOverload",
        "description": "No need to overload operators yet."
      }
    ]
  },

  "chapter_07_handling_multiples": {
    "includes": ["chapter_08_member_functions"],
    "rules": [
      {
        "queries": ["cxxMethodDecl(isExpansionInMainFile())", "cxxConstructorDecl(isExpansionInMainFile())"],
        "id": "Method",
        "description": "Make sure your structs are just data for now."
      }
    ]
  },

  "chapter_06_structuring_data": {
    "includes": ["chapter_07_handling_multiples"],
    "rules": [
      {
        "queries": ["varDecl(hasType(arrayType()), isExpansionInMainFile())", "fieldDecl(hasType(arrayType()), isExpansionInMainFile())", "declRefExpr(to(functionDecl(hasName(\"operator[]\"))), isExpansionInMainFile())", "cxxNewExpr(isExpansionInMainFile(), isArray())"],
        "id": "Array",
        "description": "For now, keep your variables holding only one piece of data at a time."
      }
    ]
  },

  "chapter_05_structuring_code": {
    "includes": ["chapter_06_structuring_data"],
    "rules": [
      {
        "queries": ["recordDecl(isExpansionInMainFile())"],
        "id": "Struct",
        "description": "Keep the code simple for now - just pass around variables seperately, don't group them."
      },
      {
        "queries": ["enumDecl(isExpansionInMainFile())"],
        "id": "Enum",
        "description": "Rather than an enum, feel free to just use a series of integer constants for now."
      }
    ]
  },

  "chapter_04_control_flow": {
    "includes": ["chapter_05_structuring_code"],
    "rules": [
      {
        "queries": ["functionDecl(isExpansionInMainFile(), unless(hasName(\"main\")), unless(cxxMethodDecl()))"],
        "id": "Function",
        "description": "Check that all your code is in the one function for now."
      },
      {
        "queries": ["cxxThrowExpr(isExpansionInMainFile())"],
        "id": "Exception",
        "description": "Simplify your error handling - you can achieve this in other ways."
      }
    ]
  },

  "chapter_03_data": {
    "includes": ["chapter_04_control_flow"],
    "rules": [
      {
        "queries": ["ifStmt(isExpansionInMainFile())", "whileStmt(isExpansionInMainFile())", "doStmt(isExpansionInMainFile())", "forStmt(isExpansionInMainFile())", "breakStmt(isExpansionInMainFile())", "continueStmt(isExpansionInMainFile())"],
        "id": "ControlFlow",
        "description": "We'll get to flow control soon! For now, keep things simple and linear."
      }
    ]
  },

  "chapter_02_sequence": {
    "includes": ["chapter_03_data"],
    "rules": [
      {
        "queries": ["varDecl(isExpansionInMainFile())"],
        "id": "Variable",
        "description": "No need for variables yet, we'll get to those next."
      },
      {
        "queries": ["callExpr(isExpansionInMainFile(), callee(namedDecl(matchesName(\"(^|::)color_\"))))"],
        "id": "ColorFunctionUsage",
        "description": "Make sure to use the provided color constants (eg. COLOR_BLUE)"
      },
      {
        "queries": ["callExpr(isExpansionInMainFile(), hasAncestor(callExpr()), unless(isExpandedFromMacro(\"a_regex_version_of_this_matcher_would_be_nice\")), unless(isExpandedFromMacro(\"COLOR_ALICE_BLUE\")), unless(isExpandedFromMacro(\"COLOR_ANTIQUE_WHITE\")), unless(isExpandedFromMacro(\"COLOR_AQUA\")), unless(isExpandedFromMacro(\"COLOR_AQUAMARINE\")), unless(isExpandedFromMacro(\"COLOR_AZURE\")), unless(isExpandedFromMacro(\"COLOR_BEIGE\")), unless(isExpandedFromMacro(\"COLOR_BISQUE\")), unless(isExpandedFromMacro(\"COLOR_BLACK\")), unless(isExpandedFromMacro(\"COLOR_BLANCHED_ALMOND\")), unless(isExpandedFromMacro(\"COLOR_BLUE\")), unless(isExpandedFromMacro(\"COLOR_BLUE_VIOLET\")), unless(isExpandedFromMacro(\"COLOR_BRIGHT_GREEN\")), unless(isExpandedFromMacro(\"COLOR_BROWN\")), unless(isExpandedFromMacro(\"COLOR_BURLY_WOOD\")), unless(isExpandedFromMacro(\"COLOR_CADET_BLUE\")), unless(isExpandedFromMacro(\"COLOR_CHARTREUSE\")), unless(isExpandedFromMacro(\"COLOR_CHOCOLATE\")), unless(isExpandedFromMacro(\"COLOR_CORAL\")), unless(isExpandedFromMacro(\"COLOR_CORNFLOWER_BLUE\")), unless(isExpandedFromMacro(\"COLOR_CORNSILK\")), unless(isExpandedFromMacro(\"COLOR_CRIMSON\")), unless(isExpandedFromMacro(\"COLOR_CYAN\")), unless(isExpandedFromMacro(\"COLOR_DARK_BLUE\")), unless(isExpandedFromMacro(\"COLOR_DARK_CYAN\")), unless(isExpandedFromMacro(\"COLOR_DARK_GOLDENROD\")), unless(isExpandedFromMacro(\"COLOR_DARK_GRAY\")), unless(isExpandedFromMacro(\"COLOR_DARK_GREEN\")), unless(isExpandedFromMacro(\"COLOR_DARK_KHAKI\")), unless(isExpandedFromMacro(\"COLOR_DARK_MAGENTA\")), unless(isExpandedFromMacro(\"COLOR_DARK_OLIVE_GREEN\")), unless(isExpandedFromMacro(\"COLOR_DARK_ORANGE\")), unless(isExpandedFromMacro(\"COLOR_DARK_ORCHID\")), unless(isExpandedFromMacro(\"COLOR_DARK_RED\")), unless(isExpandedFromMacro(\"COLOR_DARK_SALMON\")), unless(isExpandedFromMacro(\"COLOR_DARK_SEA_GREEN\")), unless(isExpandedFromMacro(\"COLOR_DARK_SLATE_BLUE\")), unless(isExpandedFromMacro(\"COLOR_DARK_SLATE_GRAY\")), unless(isExpandedFromMacro(\"COLOR_DARK_TURQUOISE\")), unless(isExpandedFromMacro(\"COLOR_DARK_VIOLET\")), unless(isExpandedFromMacro(\"COLOR_DEEP_PINK\")), unless(isExpandedFromMacro(\"COLOR_DEEP_SKY_BLUE\")), unless(isExpandedFromMacro(\"COLOR_DIM_GRAY\")), unless(isExpandedFromMacro(\"COLOR_DODGER_BLUE\")), unless(isExpandedFromMacro(\"COLOR_FIREBRICK\")), unless(isExpandedFromMacro(\"COLOR_FLORAL_WHITE\")), unless(isExpandedFromMacro(\"COLOR_FOREST_GREEN\")), unless(isExpandedFromMacro(\"COLOR_FUCHSIA\")), unless(isExpandedFromMacro(\"COLOR_GAINSBORO\")), unless(isExpandedFromMacro(\"COLOR_GHOST_WHITE\")), unless(isExpandedFromMacro(\"COLOR_GOLD\")), unless(isExpandedFromMacro(\"COLOR_GOLDENROD\")), unless(isExpandedFromMacro(\"COLOR_GRAY\")), unless(isExpandedFromMacro(\"COLOR_GRAY\")), unless(isExpandedFromMacro(\"COLOR_GREEN\")), unless(isExpandedFromMacro(\"COLOR_GREEN_YELLOW\")), unless(isExpandedFromMacro(\"COLOR_HONEYDEW\")), unless(isExpandedFromMacro(\"COLOR_HOT_PINK\")), unless(isExpandedFromMacro(\"COLOR_INDIAN_RED\")), unless(isExpandedFromMacro(\"COLOR_INDIGO\")), unless(isExpandedFromMacro(\"COLOR_IVORY\")), unless(isExpandedFromMacro(\"COLOR_KHAKI\")), unless(isExpandedFromMacro(\"COLOR_LAVENDER\")), unless(isExpandedFromMacro(\"COLOR_LAVENDER_BLUSH\")), unless(isExpandedFromMacro(\"COLOR_LAWN_GREEN\")), unless(isExpandedFromMacro(\"COLOR_LEMON_CHIFFON\")), unless(isExpandedFromMacro(\"COLOR_LIGHT_BLUE\")), unless(isExpandedFromMacro(\"COLOR_LIGHT_CORAL\")), unless(isExpandedFromMacro(\"COLOR_LIGHT_CYAN\")), unless(isExpandedFromMacro(\"COLOR_LIGHT_GOLDENROD_YELLOW\")), unless(isExpandedFromMacro(\"COLOR_LIGHT_GRAY\")), unless(isExpandedFromMacro(\"COLOR_LIGHT_GRAY\")), unless(isExpandedFromMacro(\"COLOR_LIGHT_GREEN\")), unless(isExpandedFromMacro(\"COLOR_LIGHT_PINK\")), unless(isExpandedFromMacro(\"COLOR_LIGHT_SALMON\")), unless(isExpandedFromMacro(\"COLOR_LIGHT_SEA_GREEN\")), unless(isExpandedFromMacro(\"COLOR_LIGHT_SKY_BLUE\")), unless(isExpandedFromMacro(\"COLOR_LIGHT_SLATE_GRAY\")), unless(isExpandedFromMacro(\"COLOR_LIGHT_STEEL_BLUE\")), unless(isExpandedFromMacro(\"COLOR_LIGHT_YELLOW\")), unless(isExpandedFromMacro(\"COLOR_LIME\")), unless(isExpandedFromMacro(\"COLOR_LIME_GREEN\")), unless(isExpandedFromMacro(\"COLOR_LINEN\")), unless(isExpandedFromMacro(\"COLOR_MAGENTA\")), unless(isExpandedFromMacro(\"COLOR_MAROON\")), unless(isExpandedFromMacro(\"COLOR_MEDIUM_AQUAMARINE\")), unless(isExpandedFromMacro(\"COLOR_MEDIUM_BLUE\")), unless(isExpandedFromMacro(\"COLOR_MEDIUM_ORCHID\")), unless(isExpandedFromMacro(\"COLOR_MEDIUM_PURPLE\")), unless(isExpandedFromMacro(\"COLOR_MEDIUM_SEA_GREEN\")), unless(isExpandedFromMacro(\"COLOR_MEDIUM_SLATE_BLUE\")), unless(isExpandedFromMacro(\"COLOR_MEDIUM_SPRING_GREEN\")), unless(isExpandedFromMacro(\"COLOR_MEDIUM_TURQUOISE\")), unless(isExpandedFromMacro(\"COLOR_MEDIUM_VIOLET_RED\")), unless(isExpandedFromMacro(\"COLOR_MIDNIGHT_BLUE\")), unless(isExpandedFromMacro(\"COLOR_MINT_CREAM\")), unless(isExpandedFromMacro(\"COLOR_MISTY_ROSE\")), unless(isExpandedFromMacro(\"COLOR_MOCCASIN\")), unless(isExpandedFromMacro(\"COLOR_NAVAJO_WHITE\")), unless(isExpandedFromMacro(\"COLOR_NAVY\")), unless(isExpandedFromMacro(\"COLOR_OLD_LACE\")), unless(isExpandedFromMacro(\"COLOR_OLIVE\")), unless(isExpandedFromMacro(\"COLOR_OLIVE_DRAB\")), unless(isExpandedFromMacro(\"COLOR_ORANGE\")), unless(isExpandedFromMacro(\"COLOR_ORANGE_RED\")), unless(isExpandedFromMacro(\"COLOR_ORCHID\")), unless(isExpandedFromMacro(\"COLOR_PALE_GOLDENROD\")), unless(isExpandedFromMacro(\"COLOR_PALE_GREEN\")), unless(isExpandedFromMacro(\"COLOR_PALE_TURQUOISE\")), unless(isExpandedFromMacro(\"COLOR_PALE_VIOLET_RED\")), unless(isExpandedFromMacro(\"COLOR_PAPAYA_WHIP\")), unless(isExpandedFromMacro(\"COLOR_PEACH_PUFF\")), unless(isExpandedFromMacro(\"COLOR_PERU\")), unless(isExpandedFromMacro(\"COLOR_PINK\")), unless(isExpandedFromMacro(\"COLOR_PLUM\")), unless(isExpandedFromMacro(\"COLOR_POWDER_BLUE\")), unless(isExpandedFromMacro(\"COLOR_PURPLE\")), unless(isExpandedFromMacro(\"COLOR_RED\")), unless(isExpandedFromMacro(\"COLOR_ROSY_BROWN\")), unless(isExpandedFromMacro(\"COLOR_ROYAL_BLUE\")), unless(isExpandedFromMacro(\"COLOR_SADDLE_BROWN\")), unless(isExpandedFromMacro(\"COLOR_SALMON\")), unless(isExpandedFromMacro(\"COLOR_SANDY_BROWN\")), unless(isExpandedFromMacro(\"COLOR_SEA_GREEN\")), unless(isExpandedFromMacro(\"COLOR_SEA_SHELL\")), unless(isExpandedFromMacro(\"COLOR_SIENNA\")), unless(isExpandedFromMacro(\"COLOR_SILVER\")), unless(isExpandedFromMacro(\"COLOR_SKY_BLUE\")), unless(isExpandedFromMacro(\"COLOR_SLATE_BLUE\")), unless(isExpandedFromMacro(\"COLOR_SLATE_GRAY\")), unless(isExpandedFromMacro(\"COLOR_SNOW\")), unless(isExpandedFromMacro(\"COLOR_SPRING_GREEN\")), unless(isExpandedFromMacro(\"COLOR_STEEL_BLUE\")), unless(isExpandedFromMacro(\"COLOR_SWINBURNE_RED\")), unless(isExpandedFromMacro(\"COLOR_TAN\")), unless(isExpandedFromMacro(\"COLOR_TEAL\")), unless(isExpandedFromMacro(\"COLOR_THISTLE\")), unless(isExpandedFromMacro(\"COLOR_TOMATO\")), unless(isExpandedFromMacro(\"COLOR_TRANSPARENT\")), unless(isExpandedFromMacro(\"COLOR_TURQUOISE\")), unless(isExpandedFromMacro(\"COLOR_VIOLET\")), unless(isExpandedFromMacro(\"COLOR_WHEAT\")), unless(isExpandedFromMacro(\"COLOR_WHITE\")), unless(isExpandedFromMacro(\"COLOR_WHITE_SMOKE\")), unless(isExpandedFromMacro(\"COLOR_YELLOW\")), unless(isExpandedFromMacro(\"COLOR_YELLOW_GREEN\")))"],
        "id": "FunctionReturnValue",
        "description": "Avoid using values returned from functions for now - we'll cover those next."
      }
    ]
  }
}
